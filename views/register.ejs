<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrf %>">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>Register &mdash; Sagun's Laundry</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-visual" aria-hidden="true">
    <div class="auth-visual-content">
      <div class="auth-brand-stack">
        <div class="auth-brand-mark">
          <img src="assets/saguns-brand-mark.png" alt="">
        </div>
        <div class="auth-brand-name">Sagun&rsquo;s Laundry</div>
      </div>
      <p class="auth-tagline">Create your account request and continue directly on WhatsApp.</p>
      <div class="auth-perk-box">
        <div class="auth-perk-title">Launch Ready</div>
        <ul class="auth-perks">
          <li>&#x2713; No database signup needed</li>
          <li>&#x2713; WhatsApp verification request</li>
          <li>&#x2713; Pickup &amp; delivery within 3 km</li>
        </ul>
      </div>
    </div>
  </div>

  <main class="auth-form-side">
    <div class="auth-form-container">
      <a href="index.php" class="back-link">&larr; Back to Home</a>

      <!-- Step 1: Registration -->
      <div id="step1">
        <h1 class="auth-form-title">Create Account</h1>
        <p class="auth-form-subtitle">Send your signup request to Sagun&rsquo;s Laundry on WhatsApp</p>
        <div class="auth-note">
          A true automated WhatsApp OTP needs a backend/API. This launch version sends your signup details and a verification reference to the official WhatsApp number.
        </div>
        <div id="regAlert" role="alert" aria-live="polite"></div>

        <form id="registerForm" novalidate>
          <input type="hidden" name="csrf_token" value="<%= csrf %>">

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="fullName">Full Name <span class="req">*</span></label>
              <input type="text" class="form-control" id="fullName" name="full_name"
                     placeholder="Ram Bahadur" autocomplete="name" maxlength="100" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="phone">WhatsApp Number <span class="req">*</span></label>
              <input type="tel" class="form-control" id="phone" name="phone"
                     placeholder="98XXXXXXXX" autocomplete="tel" maxlength="20" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="pickupLocation">Area / Branch Nearby</label>
              <input type="text" class="form-control" id="pickupLocation" name="pickup_location"
                     placeholder="Imadol, Nakhu, Hattiban..." maxlength="120">
            </div>
            <div class="form-group">
              <label class="form-label" for="serviceInterest">Service Needed</label>
              <select class="form-control" id="serviceInterest" name="service_interest">
                <option value="Pickup booking">Pickup booking</option>
                <option value="Regular wash">Regular wash</option>
                <option value="Premium wash">Premium wash</option>
                <option value="Dry cleaning">Dry cleaning</option>
                <option value="Ironing">Ironing</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="signupNotes">Notes</label>
            <textarea class="form-control" id="signupNotes" name="notes"
                      rows="3" placeholder="Pickup address, preferred time, or anything we should know"
                      maxlength="500"></textarea>
          </div>
          <p class="form-hint">Pickup and delivery are available up to 3 km from each branch.</p>

          <button type="submit" class="btn btn-primary btn-full btn-lg mt-2" id="registerBtn">
            Continue on WhatsApp
          </button>
        </form>
      </div>

      <div class="auth-divider"><span>or</span></div>
      <p class="auth-switch">Need help right now? <a href="<%= whatsappPickupUrl %>">Message us on WhatsApp &rarr;</a></p>
    </div>
  </main>
</div>

<script src="js/main.js?v=launch-whatsapp"></script>
<script>
document.getElementById('registerForm').addEventListener('submit', e => {
  e.preventDefault();
  const name = document.getElementById('fullName').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const area = document.getElementById('pickupLocation').value.trim();
  const service = document.getElementById('serviceInterest').value;
  const notes = document.getElementById('signupNotes').value.trim();

  if (name.length < 2 || phone.length < 7) {
    showAlert('regAlert', 'Please enter your name and WhatsApp number.', 'error');
    return;
  }

  const reference = Math.floor(100000 + Math.random() * 900000);
  const message = [
    'Hello Sagun\'s Laundry, I want to create/verify my account through WhatsApp.',
    `Signup reference/OTP: ${reference}`,
    `Name: ${name}`,
    `WhatsApp number: ${phone}`,
    area ? `Area / nearest branch: ${area}` : '',
    `Service needed: ${service}`,
    notes ? `Notes: ${notes}` : '',
    'Please confirm my signup and pickup availability.'
  ].filter(Boolean).join('\n');

  const btn = document.getElementById('registerBtn');
  setLoading(btn, true);
  setTimeout(() => goToWhatsApp(message), 250);
});
</script>
</body>
</html>
