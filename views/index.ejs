        <label for="cf_name">Your Name</label>
        <input type="text" id="cf_name" name="name" placeholder="Ram Bahadur" maxlength="100" required>
        <label for="cf_phone">Phone</label>
        <input type="tel" id="cf_phone" name="phone" placeholder="98XXXXXXXX" maxlength="20">
        <label for="cf_message">Message* <span>(pickup and delivery only within 3 km from each branch)</span></label>
        <textarea id="cf_message" name="message" rows="4" placeholder="Tell us what laundry service you need and also mention your location" maxlength="2000" required></textarea>
